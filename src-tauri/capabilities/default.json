{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "dialog:default",
        "dialog:allow-open",
        "dialog:allow-save",
        "fs:default",
        "fs:allow-read-text-file",
        "fs:allow-write-text-file",
        "fs:allow-exists",
        "fs:allow-mkdir",
        "fs:allow-rename",
        "fs:allow-copy-file",
        "fs:allow-remove",
        "shell:default",
        "opener:default"
    ]
}